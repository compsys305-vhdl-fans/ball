# ignore all files that start with an underscore, as these are generated by the build system
_*
*.wlf
*.bak
modelsim.ini

# ignore all files in the build directory
work/
db/
incremental_db/
output_files/

# ignore the .vscode directory, which contains user-specific settings
.vscode/

# ignore generated log files
log/

# quartus files
*.qws
*.rpt
*.summary
*.sopcinfo
*_assignment_defaults.qdf
*_model_dump.txt
qar_info.json
